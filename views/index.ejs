<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Members Only! Home.</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <main id="main" class="page-wrapper">
    <% if (locals.user) {%>
    <h1>Welcome back, <%= user.username %></h1>
    <nav class="nav-links" aria-label="Site navigation">
      <a href="/createMessage">Create New Message</a>
      <a href="/log-out">Log Out</a>
    </nav>
    <% } else { %>
    <h1>Hello! Log in to post:</h1>
    <form action="/log-in" method="POST">
      <label for="username">Username:</label>
      <input type="text" name="username" id="username" placeholder="username" autocomplete="username" />
      <label for="password">Password:</label>
      <input type="password" name="password" id="password" autocomplete="current-password" />
      <button type="submit">Log In</button>
    </form>
    <%}%>
    <a href="/sign-up">Sign Up</a>
    <% messages.forEach((message) => { %>
      <div class="message-div">
        <h2 class="title"><%= message.title %></h2>
        <p class="message"><%= message.text %></p>
        <% if (locals.user && user.membership_status) { %>
        <p class="username"><%= message.username %></p>
        <p class="timestamp"><%= message.timestamp %></p>
        <% } else { %>
        <p class="username">Anonymous User</p>
        <p class="timestamp">Anonymous Date</p>
        <% } %>
        <% if (locals.user && user.admin) { %>
        <form method="POST" action="/?message_id=<%= message.message_id %>">
          <button type="submit" class="delete" aria-label="Delete message: <%= message.title %>">Delete</button>
        </form>
        <% } %>
      </div>
    <% }); %>
    </main>
  </body>
</html>
